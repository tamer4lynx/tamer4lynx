# Beeceptor Mock OAuth - https://beeceptor.com/docs/tutorials/oauth-2-0-mock-usage/
# Accepts any email/password, no registration needed
OAUTH_CLIENT_ID=google-id-123
OAUTH_CLIENT_SECRET=dummy-google-secret
OAUTH_AUTHORIZATION_ENDPOINT=https://oauth-mock.mock.beeceptor.com/oauth/authorize
OAUTH_TOKEN_ENDPOINT=https://oauth-mock.mock.beeceptor.com/oauth/token/google
OAUTH_SCOPE=openid email profile
OAUTH_REDIRECT_URI=tamerdevapp://auth/callback
