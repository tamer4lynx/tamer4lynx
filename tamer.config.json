{
  "android": {
    "appName": "MyApp",
    "packageName": "com.nanofuxion.myapp",
    "sdk": "~/Library/Android/sdk"
  },
  "ios": {
    "appName": "MyApp",
    "bundleId": "com.nanofuxion.MyApp"
  },
  "icon": {
    "source": "packages/example/src/assets/tamer-logo.png",
    "androidAdaptive": {
      "foreground": "packages/example/src/assets/tamer-logo.png",
      "backgroundColor": "#000000",
      "foregroundFit": "contain",
      "foregroundScale": 0.62,
      "foregroundPadding": 6
    }
  },
  "lynxProject": "packages/example",
  "paths": {
    "androidDir": "android",
    "iosDir": "ios",
    "lynxBundleRoot": "dist",
    "lynxBundleFile": "main.lynx.bundle"
  },
  "devServer": {
    "host": "10.0.2.2",
    "port": 3000
  },
  "autolink": true
}