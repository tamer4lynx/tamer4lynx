{
  "name": "@tamer4lynx/cli",
  "version": "0.0.10",
  "module": "index.ts",
  "type": "module",
  "description": "A CLI tool for managing LynxJS native modules.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamer4lynx/tamer4lynx.git"
  },
  "homepage": "https://github.com/tamer4lynx/tamer4lynx#readme",
  "bugs": {
    "url": "https://github.com/tamer4lynx/tamer4lynx/issues"
  },
  "bin": {
    "tamer": "dist/index.js",
    "t4l": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "workspaces": [
    "packages/docs",
    "packages/example",
    "packages/tamer-auth",
    "packages/tamer-display-browser",
    "packages/tamer-linking",
    "packages/jiggle",
    "packages/tamer-transports",
    "packages/tamer-biometric",
    "packages/tamer-secure-store",
    "packages/tamer-dev-client",
    "packages/tamer-dev-app",
    "packages/tamer-host",
    "packages/tamer-icons",
    "packages/tamer-insets",
    "packages/tamer-plugin",
    "packages/tamer-router",
    "packages/tamer-screen",
    "packages/tamer-system-ui",
    "packages/tamer-app-shell"
  ],
  "keywords": [
    "lynx",
    "native",
    "module",
    "cli",
    "android",
    "ios"
  ],
  "scripts": {
    "build": "node build.mjs",
    "start": "node dist/index.js start",
    "android:build": "node dist/index.js android build",
    "android:build:install": "node dist/index.js android build --install",
    "docs:ci": "npm ci --ignore-scripts && npm run build --workspace=docs",
    "prepare": "node -e \"const fs=require('fs');if(!fs.existsSync('dist/index.js'))require('child_process').execSync('npm run build',{stdio:'inherit'})\"",
    "prepublishOnly": "npm run build",
    "publish:all": "node scripts/publish-all.mjs"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/bun": "latest",
    "@types/node": "^24.1.0",
    "@types/node-fetch": "^2.6.13",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "author": "Nanofuxion <ramnadroj@gmail.com> (https://github.com/nanofuxion)",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "baseline-browser-mapping": "^2.10.0",
    "caniuse-lite": "^1.0.30001777",
    "chokidar": "^4.0.3",
    "commander": "^14.0.0",
    "dnssd-advertise": "^1.1.3",
    "node-fetch": "^2.7.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.19.0",
    "esbuild": "^0.24.2"
  }
}
