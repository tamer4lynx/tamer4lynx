{
  "name": "tamer4lynx",
  "version": "0.0.1",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "description": "A CLI tool for managing LynxJS native modules.",
  "bin": {
    "tamer": "./dist/index.js",
    "t4l": "./dist/index.js"
  },
  "files": [
    "dist",
    "build.mjs",
    "index.ts",
    "src"
  ],
  "workspaces": [
    "packages/example",
    "packages/jiggle",
    "packages/lynxwebsockets",
    "packages/tamer-dev-client",
    "packages/tamer-dev-app",
    "packages/tamer-icons",
    "packages/tamer-insets",
    "packages/tamer-plugin",
    "packages/tamer-router",
    "packages/tamer-screen",
    "packages/tamer-system-ui",
    "packages/tamer-app-shell"
  ],
  "keywords": [
    "lynx",
    "native",
    "module",
    "cli",
    "android"
  ],
  "scripts": {
    "build": "node build.mjs",
    "start": "node dist/index.js start",
    "android:build": "node dist/index.js android build",
    "android:build:install": "node dist/index.js android build --install",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.1.0",
    "@types/node-fetch": "^2.6.13",
    "esbuild": "^0.24.2",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "author": "Nanofuxion <ramnadroj@gmail.com> (https://github.com/nanofuxion)",
  "license": "MIT",
  "dependencies": {
    "@types/adm-zip": "^0.5.7",
    "adm-zip": "^0.5.16",
    "baseline-browser-mapping": "^2.10.0",
    "caniuse-lite": "^1.0.30001777",
    "chokidar": "^4.0.3",
    "commander": "^14.0.0",
    "dnssd-advertise": "^1.1.3",
    "node-fetch": "^2.7.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.19.0"
  }
}
